import React, { useState } from 'react';
import { Cake, Mail, MapPin, Phone, Clock, ArrowUp, Send, CheckCircle2 } from 'lucide-react';

interface FooterProps {
  setCurrentTab: (tab: string) => void;
}

export default function Footer({ setCurrentTab }: FooterProps) {
  const [newsEmail, setNewsEmail] = useState('');
  const [subscribed, setSubscribed] = useState(false);

  const handleSubscribe = (e: React.FormEvent) => {
    e.preventDefault();
    if (!newsEmail) return;
    setSubscribed(true);
    setNewsEmail('');
  };

  const handleScrollTop = () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  };

  return (
    <footer className="bg-[#2D2621] text-stone-300 border-t border-[#3A312B]" id="bakery-footer">
      
      {/* Upper Newsletter Promo Row */}
      <div className="border-b border-[#3A312B] py-12 bg-[#26201B]">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div className="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center text-left">
            <div className="lg:col-span-6">
              <h3 className="font-serif text-lg sm:text-xl font-bold text-[#EFEAE4]">Join the Confection Club</h3>
              <p className="font-sans text-xs text-stone-400 mt-1">Receive secret recipes, early tasting invites, and seasonal artisan design schedules.</p>
            </div>
            
            <div className="lg:col-span-6">
              {subscribed ? (
                <div className="flex gap-2.5 items-center p-3.5 bg-amber-950/40 rounded-xl border border-amber-800/40 text-stone-200" id="news-success">
                  <CheckCircle2 className="w-5 h-5 text-amber-300 shrink-0" />
                  <span className="text-xs font-serif font-bold">You are subscribed! We will email you seasonal tastings soon.</span>
                </div>
              ) : (
                <form onSubmit={handleSubscribe} className="flex gap-2">
                  <input
                    type="email"
                    required
                    placeholder="confectioner@noble.com"
                    value={newsEmail}
                    onChange={(e) => setNewsEmail(e.target.value)}
                    className="flex-1 bg-stone-800/80 border border-stone-700 rounded-xl px-4 py-3 text-xs sm:text-sm text-stone-100 placeholder-stone-500 focus:outline-none focus:ring-1 focus:ring-amber-500"
                  />
                  <button
                    type="submit"
                    className="bg-amber-800 hover:bg-amber-900 text-[#FAF8F5] px-5 py-3 rounded-xl hover:shadow-lg transition-all text-xs font-semibold uppercase tracking-wider flex items-center gap-1 shrink-0"
                    id="news-btn-submit"
                  >
                    <span>Send</span>
                    <Send className="w-3.5 h-3.5" />
                  </button>
                </form>
              )}
            </div>
          </div>
        </div>
      </div>

      {/* Main Footer Sitemap Grid */}
      <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-left">
        <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-10">
          
          {/* Brand Info */}
          <div className="lg:col-span-4" id="footer-branding">
            <div className="flex items-center gap-2.5 mb-4">
              <div className="w-8 h-8 rounded-full bg-amber-950 text-amber-300 border border-amber-800 flex items-center justify-center">
                <Cake className="w-4 h-4" />
              </div>
              <span className="font-serif text-xl tracking-wider text-white font-bold">HENKAR</span>
            </div>
            
            <p className="font-sans text-xs text-stone-400 leading-relaxed max-w-sm">
              Artisan luxury custom tiered cakes and exquisite confections handcrafted for extraordinary weddings and celebrations across the nation.
            </p>

            <div className="mt-6 flex flex-col gap-2 text-xs text-stone-400">
              <span className="flex items-center gap-2.5">
                <MapPin className="w-4 h-4 text-amber-700 shrink-0" />
                <span>12 Conduit Passage, Mayfair, London W1S 2XS</span>
              </span>
              <span className="flex items-center gap-2.5">
                <Phone className="w-4 h-4 text-amber-700 shrink-0" />
                <span>+44 (0) 20 7946 0192</span>
              </span>
            </div>
          </div>

          {/* Sitemap links */}
          <div className="lg:col-span-3 lg:offset-1" id="footer-sitemap">
            <h4 className="font-serif text-sm font-semibold tracking-wide text-white mb-4">The Atelier Suite</h4>
            <div className="flex flex-col space-y-2.5 text-xs text-stone-400">
              {[
                { id: 'home', label: 'Welcome Lounge' },
                { id: 'gallery', label: 'Bespoke Design Gallery' },
                { id: 'services', label: 'Atelier Service Offerings' },
                { id: 'customizer', label: 'Live Customizer Simulator' },
                { id: 'about', label: 'Our Story & Ingredients' }
              ].map((link) => (
                <button
                  key={link.id}
                  onClick={() => setCurrentTab(link.id)}
                  className="hover:text-amber-400 text-left transition-colors duration-250 cursor-pointer"
                >
                  {link.label}
                </button>
              ))}
            </div>
          </div>

          {/* Operation timetables */}
          <div className="lg:col-span-3" id="footer-timetable">
            <h4 className="font-serif text-sm font-semibold tracking-wide text-white mb-4">Tasting Room Hours</h4>
            <div className="space-y-3 text-xs text-stone-400">
              <div className="flex justify-between border-b border-stone-800 pb-1">
                <span>Tuesday - Thursday:</span>
                <span className="text-stone-300 font-semibold">10:00 AM - 5:00 PM</span>
              </div>
              <div className="flex justify-between border-b border-stone-800 pb-1">
                <span>Friday - Saturday:</span>
                <span className="text-stone-300 font-semibold">9:00 AM - 6:00 PM</span>
              </div>
              <div className="flex justify-between pb-1">
                <span>Sunday & Monday:</span>
                <span className="text-amber-500 bg-amber-950/20 px-1.5 py-0.5 rounded leading-none">Studio Closed</span>
              </div>
              <div className="flex items-center gap-2 text-[11px] text-stone-500 mt-4 leading-normal">
                <Clock className="w-4 h-4 text-amber-800 shrink-0" />
                <span>*Pickup orders require scheduled pickup appointments at checkout.</span>
              </div>
            </div>
          </div>

          {/* Top return arrow */}
          <div className="lg:col-span-2 flex items-start md:justify-end" id="footer-backtop">
            <button
              onClick={handleScrollTop}
              className="p-3 bg-stone-800 hover:bg-stone-700 border border-stone-700 rounded-xl text-stone-350 transition-colors duration-200"
              title="Return to top"
            >
              <ArrowUp className="w-5 h-5" />
            </button>
          </div>

        </div>

        {/* Brand Copyright */}
        <div className="border-t border-[#3A312B] pt-8 mt-12 text-center text-[11px] text-stone-500 flex flex-col sm:flex-row justify-between" id="footer-bottom">
          <p>© 2026 Henkar Cakes. All rights reserved. Sculpted Confectionery Masterworks.</p>
          <p className="mt-1 sm:mt-0">Mayfair Atelier • Delivered Worldwide with White-glove Air-carriage setup</p>
        </div>
      </div>
    </footer>
  );
}
