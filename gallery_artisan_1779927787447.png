import React, { useState, useEffect } from 'react';
import Header from './components/Header';
import Hero from './components/Hero';
import AboutSection from './components/AboutSection';
import ServicesSection from './components/ServicesSection';
import GallerySection from './components/GallerySection';
import CakeCustomizer from './components/CakeCustomizer';
import InquiryHistory from './components/InquiryHistory';
import Footer from './components/Footer';
import { CakeQuoteRequest } from './types';
import { Calendar, ChevronRight, Sparkles, Heart } from 'lucide-react';

export default function App() {
  const [currentTab, setCurrentTab] = useState<string>('home');
  const [inquiries, setInquiries] = useState<(CakeQuoteRequest & { id: string; priceEstimate: number; timestamp: string })[]>([]);
  
  // Transport configuration parameters from Gallery to Designer
  const [preconfiguredCake, setPreconfiguredCake] = useState<{
    shape: 'round' | 'square' | 'hexagon';
    tiers: number;
    finish: 'smooth_fondant' | 'textured_buttercream' | 'naked_rustic' | 'geode_sculpt';
    flavor: string;
  } | null>(null);

  // Sync saved inquiry logs continuously over browser reloads
  useEffect(() => {
    try {
      const stored = localStorage.getItem('henkar_cakes_inquiries');
      if (stored) {
        setInquiries(JSON.parse(stored));
      }
    } catch (e) {
      console.error('Local Storage error reading inquiries', e);
    }
  }, []);

  const handleAddInquiry = (newInquiry: CakeQuoteRequest & { id: string; priceEstimate: number; timestamp: string }) => {
    const updated = [newInquiry, ...inquiries];
    setInquiries(updated);
    try {
      localStorage.setItem('henkar_cakes_inquiries', JSON.stringify(updated));
    } catch (e) {
      console.error('Local Storage saving error', e);
    }
  };

  const handleRemoveInquiry = (id: string) => {
    const updated = inquiries.filter(iq => iq.id !== id);
    setInquiries(updated);
    try {
      localStorage.setItem('henkar_cakes_inquiries', JSON.stringify(updated));
    } catch (e) {
      console.error('Local Storage saving error', e);
    }
  };

  // Render secondary active sub-structures inside the main view
  const renderContent = () => {
    switch (currentTab) {
      case 'home':
        return (
          <div className="animate-fadeIn">
            <Hero setCurrentTab={setCurrentTab} />
            
            {/* Split welcome display teaser with CTA to tasting booking */}
            <div className="py-20 bg-white border-t border-[#E8E2D9]">
              <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div className="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center text-left">
                  <div>
                    <span className="text-xs uppercase font-semibold text-amber-800 tracking-wider">The Confection Standards</span>
                    <h2 className="font-serif text-3xl font-bold text-[#2C2621] mt-1.5 mb-5 leading-tight">
                      Designed to Perfection, <br />Baked with Devotion
                    </h2>
                    <p className="font-sans text-sm text-[#60554B] leading-relaxed mb-6">
                      Every tier prepared in Henkar Cakes passes through visual and taste inspection before dispatch. From micro gold foil inclusions inside our crystal caverns, to traditional double-milled almond structures for high-tea dessert bars, we handle variables gracefully.
                    </p>
                    <div className="space-y-4">
                      <div className="flex gap-4 p-4 rounded-2xl bg-[#FAF7F2] border border-[#EDE5DC]">
                        <div className="w-10 h-10 rounded-full bg-rose-50 border border-rose-150 flex items-center justify-center shrink-0 text-rose-800">
                          <Heart className="w-5 h-5" />
                        </div>
                        <div>
                          <h4 className="font-serif text-sm font-semibold text-[#2C2621]">Complementary Wedding Anniversary Tier</h4>
                          <p className="text-xs text-[#7A6E63] mt-0.5">We construct a dedicated matching micro-tier to remain in your freezer, ready to commemorate your first anniversary.</p>
                        </div>
                      </div>

                      <div className="flex gap-4 p-4 rounded-2xl bg-[#FAF7F2] border border-[#EDE5DC]">
                        <div className="w-10 h-10 rounded-full bg-amber-50 border border-amber-150 flex items-center justify-center shrink-0 text-amber-800">
                          <Sparkles className="w-5 h-5 animate-spin-slow" />
                        </div>
                        <div>
                          <h4 className="font-serif text-sm font-semibold text-[#2C2621]">Private Atelier Tastings</h4>
                          <p className="text-xs text-[#7A6E63] mt-0.5">Meet one-on-one with Chef Henkar on Tuesdays to sample hot cake textures, custom lavender honeys, and sketch your reception drafts.</p>
                        </div>
                      </div>
                    </div>
                  </div>

                  {/* Creative Interactive Teaser promo banner */}
                  <div className="relative">
                    <div className="absolute inset-0 bg-[#F4EDE4] rounded-3xl transform rotate-2 border border-[#E8E2D9]"></div>
                    <div className="relative bg-[#FAF7F2] rounded-3xl p-8 border border-[#E0D8CE] text-left">
                      <span className="block text-[10px] font-mono text-amber-800 font-bold uppercase tracking-widest leading-none mb-2">Live Testing Simulator</span>
                      <h3 className="font-serif text-xl sm:text-2xl text-[#2C2621] font-bold mb-4">Try Our Interactive Cake Studio</h3>
                      <p className="font-sans text-xs text-[#60554B] leading-relaxed mb-6">
                        Don’t leave configurations to imagination. Combine cylinders shapes, stacked tiers height, rustic cream scrapings or edible sugar gems using our live visualizer. We’ll calculate an estimated ledger instantly for your planner.
                      </p>
                      
                      <div className="flex gap-3 text-xs justify-start items-center p-3 bg-white rounded-xl mb-6 border border-[#EDE5DC]">
                        <div className="w-3 h-3 rounded-full bg-amber-600 animate-pulse shrink-0" />
                        <span className="text-[#60554B] leading-none">Estimate, flavor details, and customizer are active.</span>
                      </div>

                      <button
                        onClick={() => setCurrentTab('customizer')}
                        className="w-full sm:w-auto px-6 py-3.5 bg-amber-800 hover:bg-amber-900 text-white rounded-xl text-xs font-semibold uppercase tracking-wider shadow-sm transition-all duration-300 flex items-center justify-center gap-2"
                      >
                        <span>Launch Customizer</span>
                        <ChevronRight className="w-4 h-4 text-amber-300" />
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            {/* Featured Section of Gallery inside Home page view */}
            <div className="py-20 bg-[#FAF7F2] border-t border-[#E8E2D9]">
              <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <span className="text-xs uppercase font-semibold text-amber-850 tracking-widest">Selected Masterworks</span>
                <h2 className="font-serif text-3xl font-bold text-[#2C2621] mt-2 mb-12">Sculpted for Celebrations</h2>
                
                <GallerySection 
                  setCurrentTab={setCurrentTab} 
                  setPreconfiguredCake={setPreconfiguredCake} 
                />
              </div>
            </div>
          </div>
        );
      case 'gallery':
        return (
          <div className="animate-fadeIn">
            <GallerySection 
              setCurrentTab={setCurrentTab} 
              setPreconfiguredCake={setPreconfiguredCake} 
            />
          </div>
        );
      case 'services':
        return (
          <div className="animate-fadeIn">
            <ServicesSection setCurrentTab={setCurrentTab} />
          </div>
        );
      case 'customizer':
        return (
          <div className="animate-fadeIn">
            <CakeCustomizer 
              onAddInquiry={handleAddInquiry} 
              preconfigured={preconfiguredCake} 
              clearPreconfigured={() => setPreconfiguredCake(null)} 
            />
            <InquiryHistory 
              inquiries={inquiries} 
              onRemoveInquiry={handleRemoveInquiry} 
            />
          </div>
        );
      case 'about':
        return (
          <div className="animate-fadeIn">
            <AboutSection />
          </div>
        );
      default:
        return <Hero setCurrentTab={setCurrentTab} />;
    }
  };

  return (
    <div className="min-h-screen flex flex-col bg-[#FDFBF7] text-[#2C2621] font-sans antialiased">
      {/* Dynamic Header */}
      <Header 
        currentTab={currentTab} 
        setCurrentTab={setCurrentTab} 
        quoteCount={inquiries.length} 
      />

      {/* Main Container Views mounting */}
      <main className="flex-grow">
        {renderContent()}
      </main>

      {/* Dynamic Footer */}
      <Footer setCurrentTab={setCurrentTab} />
    </div>
  );
}
