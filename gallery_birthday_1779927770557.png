@import "tailwindcss";

@theme {
  --font-sans: "Inter", ui-sans-serif, system-ui, sans-serif;
  --font-serif: "Playfair Display", Georgia, Cambria, "Times New Roman", Times, serif;
}

/* Custom Confection Visual Textures for Live Design Studio Mockups */

.clip-hex {
  clip-path: polygon(20% 0%, 80% 0%, 100% 50%, 80% 100%, 20% 100%, 0% 50%);
}

.combed-texture {
  background-image: repeating-linear-gradient(
    0deg, 
    rgba(74, 59, 50, 0.06) 0px, 
    rgba(74, 59, 50, 0.06) 2px, 
    transparent 2px, 
    transparent 10px
  );
}

.naked-texture {
  background-image: 
    linear-gradient(
      90deg, 
      rgba(255, 255, 255, 0.25) 0%, 
      transparent 15%, 
      transparent 85%, 
      rgba(0, 0, 0, 0.1) 100%
    ),
    repeating-linear-gradient(
      0deg, 
      #FFF8ED 0px, 
      #FFF8ED 18px, 
      #A68050 18px, 
      #A68050 32px
    );
  background-blend-mode: multiply;
}

.geode-cavity {
  position: relative;
}

.geode-cavity::after {
  content: '';
  position: absolute;
  top: 15%;
  left: 30%;
  width: 32%;
  height: 70%;
  border-radius: 9999px;
  background: radial-gradient(circle, #34d399 10%, #065f46 60%, #b45309 85%, transparent 100%);
  border: 2px solid #fbbf24;
  box-shadow: inset 0 0 10px rgba(0,0,0,0.6), 0 0 8px rgba(52,211,153,0.4);
  animation: pulse-glow 3s infinite ease-in-out;
  pointer-events: none;
}

/* Keyframes and Visual Animations */

@keyframes pulse-glow {
  0%, 100% {
    opacity: 0.95;
    transform: scale(1);
    box-shadow: inset 0 0 10px rgba(0,0,0,0.6), 0 0 6px rgba(52,211,153,0.3);
  }
  50% {
    opacity: 1;
    transform: scale(1.04);
    box-shadow: inset 0 0 12px rgba(0,0,0,0.7), 0 0 16px rgba(52,211,153,0.6);
  }
}

.animate-spin-slow {
  animation: spin 16s linear infinite;
}

.animate-fadeIn {
  animation: fadeIn 0.45s ease-out forwards;
}

.animate-scaleIn {
  animation: scaleIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.animate-slideDown {
  animation: slideDown 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(4px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.97) translateY(8px);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
